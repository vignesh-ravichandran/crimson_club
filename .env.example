# Crimson Club — single sample env file for this repo (extend this file only; do not add .env.sample / .env.local.example).
# Copy to .env / .env.local for next dev or use .dev.vars for wrangler.
# Never commit real secrets. See docs/deployment/env-and-config.md.

# Required (min 32 chars): used to sign/verify session cookie. For local dev, set in .env.local.
SESSION_SECRET=

# Optional: path to local SQLite for next dev (default: .data/local.sqlite)
# DATABASE_PATH=.data/local.sqlite
